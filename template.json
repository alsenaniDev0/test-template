{
  "id": "sample-all-fields-template",
  "name": "قالب تجريبي شامل",
  "version": "1.0.0",
  "schemaVersion": "1.0.0",
  "type": "custom",
  "language": "ar",
  "direction": "rtl",
  "html": "index.html",
  "css": "style.css",
  "settings": {
    "exportable": true,
    "exportTypes": [
      "png",
      "pdf"
    ],
    "width": 1080,
    "height": 1920,
    "exportFileName": "safhat-design"
  },
  "features": {
    "feelings": {
      "enabled": true,
      "approvalMode": "manual",
      "preventDuplicate": true,
      "rateLimitMinutes": 5,
      "title": "الرسائل",
      "description": "يمكن للزائر ترك رسالة"
    },
    "rsvp": {
      "enabled": true,
      "preventDuplicate": true,
      "nameRequired": false,
      "title": "تأكيد الحضور",
      "description": "يمكن للزائر اختيار حالة الحضور"
    }
  },
  "fields": [
    {
      "key": "theme",
      "label": "الثيم",
      "type": "select",
      "formTab": "design",
      "defaultValue": "classic",
      "required": true,
      "options": [
        {
          "label": "كلاسيك",
          "value": "classic"
        },
        {
          "label": "فاخر",
          "value": "luxury"
        }
      ]
    },
    {
      "key": "showLogo",
      "label": "إظهار الصورة",
      "type": "select",
      "formTab": "design",
      "defaultValue": "yes",
      "required": true,
      "options": [
        {
          "label": "نعم",
          "value": "yes"
        },
        {
          "label": "لا",
          "value": "no"
        }
      ]
    },
    {
      "key": "icon",
      "label": "الأيقونة",
      "type": "icon",
      "formTab": "design",
      "defaultValue": "✨",
      "options": [
        {
          "label": "✨",
          "value": "✨"
        },
        {
          "label": "💌",
          "value": "💌"
        },
        {
          "label": "🎉",
          "value": "🎉"
        }
      ]
    },
    {
      "key": "logo",
      "label": "الصورة",
      "type": "image",
      "defaultValue": "https://placehold.co/600x600/e0f2fe/0369a1?text=Safhat",
      "visibleWhen": {
        "field": "showLogo",
        "equals": "yes"
      },
      "requiredWhen": {
        "field": "showLogo",
        "equals": "yes"
      },
      "imageCrop": {
        "enabled": true,
        "aspectRatio": "square",
        "outputWidth": 900,
        "outputHeight": 900,
        "maxWidth": 1400,
        "maxHeight": 1400,
        "quality": 0.9
      }
    },
    {
      "key": "eyebrow",
      "label": "النص العلوي",
      "type": "text",
      "defaultValue": "مرحبًا بكم",
      "required": true,
      "maxLength": 80
    },
    {
      "key": "title",
      "label": "العنوان",
      "type": "text",
      "defaultValue": "عنوان التصميم",
      "required": true,
      "minLength": 3,
      "maxLength": 80,
      "designControls": {
        "font": {
          "enabled": true,
          "label": "خط العنوان",
          "selector": ".title"
        }
      }
    },
    {
      "key": "description",
      "label": "الوصف",
      "type": "textarea",
      "defaultValue": "اكتب وصفًا قصيرًا يظهر في التصميم.",
      "required": true,
      "minLength": 10,
      "maxLength": 240
    },
    {
      "key": "names",
      "label": "الأسماء",
      "type": "names",
      "separator": " و ",
      "minItems": 1,
      "maxItems": 3,
      "placeholder": "مثال: محمد",
      "required": true,
      "designControls": {
        "font": {
          "enabled": true,
          "label": "خط الأسماء",
          "selector": ".names"
        }
      }
    },
    {
      "key": "date",
      "label": "التاريخ",
      "type": "date",
      "required": true
    },
    {
      "key": "time",
      "label": "الوقت",
      "type": "time",
      "defaultValue": "20:00"
    },
    {
      "key": "locationUrl",
      "label": "الموقع",
      "type": "map",
      "required": true,
      "placeholder": "اختر الموقع من الخريطة"
    },
    {
      "key": "audioTrack",
      "label": "ملف صوتي",
      "type": "audio",
      "required": false
    },
    {
      "key": "youtubeUrl",
      "label": "رابط YouTube",
      "type": "youtube",
      "placeholder": "https://youtu.be/...",
      "pattern": "^https?:\\/\\/.+",
      "patternMessage": "الرابط يجب أن يبدأ بـ http أو https"
    },
    {
      "key": "skills",
      "label": "قائمة بسيطة",
      "type": "list",
      "listStyle": "tags",
      "defaultValue": [
        "تصميم جاهز",
        "سهل التخصيص"
      ],
      "minItems": 1,
      "maxItems": 8
    },
    {
      "key": "services",
      "label": "عناصر متكررة",
      "type": "repeater",
      "minItems": 1,
      "maxItems": 4,
      "itemFields": [
        {
          "key": "title",
          "label": "العنوان",
          "type": "text",
          "required": true,
          "maxLength": 60
        },
        {
          "key": "description",
          "label": "الوصف",
          "type": "textarea",
          "maxLength": 180
        },
        {
          "key": "url",
          "label": "رابط",
          "type": "url"
        },
        {
          "key": "points",
          "label": "نقاط",
          "type": "list",
          "maxItems": 5
        }
      ]
    },
    {
      "key": "primaryColor",
      "label": "اللون الأساسي",
      "type": "color",
      "formTab": "design",
      "defaultValue": "#7c3aed"
    },
    {
      "key": "accentColor",
      "label": "لون التمييز",
      "type": "color",
      "formTab": "design",
      "defaultValue": "#06b6d4"
    },
    {
      "key": "textColor",
      "label": "لون النص",
      "type": "color",
      "formTab": "design",
      "defaultValue": "#111827"
    },
    {
      "key": "themeColors",
      "label": "ألوان الثيم",
      "type": "colors",
      "formTab": "design",
      "defaultValue": {
        "background": "#f8fafc",
        "card": "#ffffff"
      },
      "options": [
        {
          "label": "الخلفية",
          "value": "background"
        },
        {
          "label": "البطاقة",
          "value": "card"
        }
      ]
    },
    {
      "key": "feelingsTitle",
      "label": "عنوان الرسائل",
      "type": "text",
      "defaultValue": "شارك مشاعرك"
    },
    {
      "key": "feelingsDescription",
      "label": "وصف الرسائل",
      "type": "textarea",
      "defaultValue": "اكتب رسالة قصيرة لصاحب التصميم."
    },
    {
      "key": "rsvpTitle",
      "label": "عنوان الحضور",
      "type": "text",
      "defaultValue": "هل ستحضر؟"
    },
    {
      "key": "rsvpDescription",
      "label": "وصف الحضور",
      "type": "textarea",
      "defaultValue": "يسعدنا معرفة حضورك."
    },
    {
      "key": "closing",
      "label": "الخاتمة",
      "type": "textarea",
      "defaultValue": "شكرًا لكم.",
      "required": true
    }
  ],
  "sections": [
    {
      "key": "logo",
      "selector": "[data-section='logo']",
      "visibleWhen": {
        "field": "showLogo",
        "equals": "yes"
      }
    },
    {
      "key": "audio",
      "selector": "[data-section='audio']",
      "visibleWhen": {
        "field": "audioTrack",
        "exists": true
      }
    },
    {
      "key": "youtube",
      "selector": "[data-section='youtube']",
      "visibleWhen": {
        "field": "youtubeUrl",
        "exists": true
      }
    },
    {
      "key": "feelings",
      "selector": "[data-feature='feelings']"
    },
    {
      "key": "rsvp",
      "selector": "[data-feature='rsvp']"
    }
  ],
  "exportTypes": [
    "png",
    "pdf"
  ],
  "order": 1,
  "isActive": true
}